---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: string;
}

const SITE = 'https://cairnsairconcleaning.com.au';
const PHONE_DISPLAY = '+61 485 939 966';
const PHONE_TEL = '+61485939966';
const EMAIL = 'quotes@cairnsairconcleaning.com.au';
const BIZ_NAME = 'Cairns Aircon Cleaning';

const { title, description, canonical = SITE + '/', ogType = 'website' } = Astro.props;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "HVACBusiness",
  "@id": SITE + "/#business",
  "name": BIZ_NAME,
  "image": SITE + "/images/og-image.jpg",
  "url": SITE,
  "priceRange": "$$",
  "description": "Split-system and ducted air conditioning install, repair and service across the Sunshine Coast. ARCtick refrigerant-licensed, QBCC-licensed installers. Daikin, Mitsubishi, Fujitsu and Panasonic systems, sized to the room. Year-round cooling for the sub-tropical Sunshine Coast climate, salt-air-aware coastal installs, commercial maintenance contracts.",
  "areaServed": [
    { "@type": "City", "name": "Sunshine Coast", "containedInPlace": { "@type": "AdministrativeArea", "name": "Sunshine Coast Region" } },
    { "@type": "City", "name": "Maroochydore" },
    { "@type": "City", "name": "Caloundra" },
    { "@type": "City", "name": "Buderim" },
    { "@type": "City", "name": "Mooloolaba" },
    { "@type": "City", "name": "Nambour" },
    { "@type": "City", "name": "Coolum" },
    { "@type": "City", "name": "Sippy Downs" },
    { "@type": "City", "name": "Kawana" },
    { "@type": "City", "name": "Noosa" }
  ],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Sunshine Coast",
    "addressRegion": "QLD",
    "postalCode": "4558",
    "addressCountry": "AU"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -26.6500,
    "longitude": 153.0667
  },
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "07:00",
    "closes": "17:00"
  }],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Air Conditioning Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Split System Installation" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Ducted Air Conditioning" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Air Conditioning Repairs" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Service & Maintenance" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Commercial Air Conditioning" }}
    ]
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": SITE + "/#website",
  "url": SITE + "/",
  "name": BIZ_NAME,
  "inLanguage": "en-AU",
  "publisher": { "@id": SITE + "/#business" }
};
// BreadcrumbList JSON-LD auto-generated from Astro.url.pathname
const pathname = Astro.url.pathname;
const breadcrumbSegments = pathname.split('/').filter(Boolean);
const breadcrumbItems = [{ "@type": "ListItem", "position": 1, "name": "Home", "item": SITE + "/" }];
let cumulative = SITE;
breadcrumbSegments.forEach((seg, i) => {
  cumulative += '/' + seg;
  // Human-friendly name: kebab → Title Case, special-case 'services' → Services
  const friendly = seg === 'services'
    ? 'Services'
    : seg.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
  breadcrumbItems.push({
    "@type": "ListItem",
    "position": i + 2,
    "name": friendly,
    "item": cumulative + '/'
  });
});
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems
};

---
<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonical}>
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
  <meta name="theme-color" content="#0b4f6c">

  <meta property="og:type" content={ogType}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonical}>
  <meta property="og:locale" content="en_AU">
  <meta property="og:site_name" content={BIZ_NAME}>
  <meta property="og:image" content={SITE + "/images/og-image.jpg"}>
  <meta property="og:image:secure_url" content={SITE + "/images/og-image.jpg"}>
  <meta property="og:image:type" content="image/jpeg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content={BIZ_NAME + " — free quote, call today"}>

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={SITE + "/images/og-image.jpg"}>
  <meta name="twitter:image:alt" content={BIZ_NAME + " — free quote, call today"}>

  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;800&family=Playfair+Display:wght@900&family=Stardos+Stencil:wght@700&display=swap">

  <!-- Google Search Console verification (DNS TXT primary; meta backup) -->
  <meta name="google-site-verification" content="GSC-TOKEN-PLACEHOLDER">

  <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin>
  <link rel="dns-prefetch" href="https://www.googletagmanager.com">
  <link rel="dns-prefetch" href="https://www.google-analytics.com">

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-GH5V2MSMZF"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-GH5V2MSMZF', {
      'send_page_view': true,
      'anonymize_ip': true
    });
  </script>

  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <slot name="head" />
</head>
<body>
  <div class="top-bar">
    <span>Split-system &amp; ducted air con &middot; Install, service &amp; repair &middot; Servicing the Sunshine Coast &middot; <a class="ph-cta" href="/quote/" aria-label="Call us"><span aria-hidden="true">&#9742;</span><span class="ph-text">&nbsp;Tap to call</span></a></span>
  </div>

  <header class="site-header">
    <div class="nav-wrap">
      <a class="brand" href="/" aria-label="Sunshine Coast Aircon Service home">
        <img src="/images/logo.svg" alt="Sunshine Coast Aircon Service" width="320" height="80" decoding="async">
      </a>
      <ul class="nav-links">
        <li><a href="/services/split-system-install/">Split Systems</a></li>
        <li><a href="/services/ducted-air-conditioning/">Ducted</a></li>
        <li><a href="/services/aircon-repairs/">Repairs</a></li>
        <li><a href="/services/aircon-service/">Service</a></li>
        <li><a href="/services/commercial-aircon/">Commercial</a></li>
        <li><a href="/sunshine-coast-region/">Areas</a></li>
      </ul>
      <a class="nav-cta" href="/quote/">Get a Quote</a>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div>
        <h4>Sunshine Coast Aircon Service</h4>
        <p style="margin-bottom: 0.75rem;">ARCtick refrigerant-licensed, QBCC-licensed air conditioning installers serving the Sunshine Coast. Split-system and ducted supply &amp; install, all-brand repairs, annual servicing and commercial maintenance &mdash; sized and installed for the sub-tropical climate.</p>
        <p style="margin-bottom: 0.5rem;"><strong style="color:#fff;">Phone:</strong> <a class="ph-cta" href="/quote/" aria-label="Call us"><span aria-hidden="true">&#9742;</span><span class="ph-text">&nbsp;Tap to call</span></a></p>
        <p style="margin-bottom: 0.5rem;"><strong style="color:#fff;">Hours:</strong> Mon&ndash;Sat 7am&ndash;5pm AEST</p>
        <p style="margin-bottom: 0.5rem;"><strong style="color:#fff;">Service area:</strong> Full Sunshine Coast Region &mdash; Caloundra to Noosa</p>
        <p style="margin-bottom: 0;"><strong style="color:#fff;">ABN:</strong> 91 664 546 061</p>
      </div>
      <div>
        <h4>Services</h4>
        <ul>
          <li><a href="/services/split-system-install/">Split system installation</a></li>
          <li><a href="/services/ducted-air-conditioning/">Ducted air conditioning</a></li>
          <li><a href="/services/aircon-repairs/">Air conditioning repairs</a></li>
          <li><a href="/services/aircon-service/">Service &amp; maintenance</a></li>
          <li><a href="/services/commercial-aircon/">Commercial air conditioning</a></li>
        </ul>
      </div>
      <div>
        <h4>Service Areas</h4>
        <ul>
          <li><a href="/maroochydore/">Maroochydore</a></li>
          <li><a href="/caloundra/">Caloundra</a></li>
          <li><a href="/buderim/">Buderim</a></li>
          <li><a href="/mooloolaba/">Mooloolaba</a></li>
          <li><a href="/nambour/">Nambour</a></li>
          <li><a href="/sunshine-coast-region/">All Sunshine Coast Region</a></li>
        </ul>
      </div>
      <div>
        <h4>Resources</h4>
        <ul>
          <li><a href="/pricing/">Pricing guide</a></li>
          <li><a href="/local-trades/">Local trades directory</a></li>
        </ul>
      </div>
    </div>
    <p class="footer-bottom">
      &copy; {new Date().getFullYear()} {BIZ_NAME} &middot; Yes Right Pty Ltd ABN 91 664 546 061. Split-system &amp; ducted air conditioning install, repair &amp; service across the Sunshine Coast.
    </p>
  </footer>

  <a class="mobile-phone ph-cta" href="/quote/" aria-label="Call us">
    <span aria-hidden="true">&#9742;</span><span class="ph-text">&nbsp;Tap to call</span>
  </a>
  <script is:inline>
    (function(){
      // 2026-05-23: phone assembled from non-contiguous fragments
      // so no contiguous phone-number substring exists in static HTML.
      // Google can index attributes & visible text; the .ph-cta links default to /quote/
      // for no-JS users, and JS rewrites href to tel: + injects display text.
      var p1 = 485, p2 = 939, p3 = 966;
      var disp = '0' + p1 + ' ' + p2 + ' ' + p3;
      var tel  = '+61' + p1 + p2 + p3;
      document.querySelectorAll('.ph-cta').forEach(function(el){
        el.setAttribute('href', 'tel:' + tel);
        el.setAttribute('aria-label', 'Call ' + disp);
        var t = el.querySelector('.ph-text');
        if (t) t.textContent = ' ' + disp;
      });
    })();
  </script>
</body>
</html>
