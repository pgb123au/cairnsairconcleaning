const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do I need an ARCtick licence for cleaning if no refrigerant is removed?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Strictly, the ARCtick refrigerant handling licence (RHL) is triggered when a technician disturbs the sealed refrigerant circuit, recovers gas, or works on the flare connections at the indoor or outdoor unit. A plain wash of the evaporator face on a unit you do not disconnect is grey-area, but the moment a tech pulls the indoor head off the wall, separates the flare to access the coil properly, or services the condenser at the outdoor unit, ARCtick applies under the Ozone Protection and Synthetic Greenhouse Gas Management Act 1989. We default to sending an ARCtick-licensed cleaning tech to every Cairns job because once we have eyes on the system we usually find something that requires refrigerant work."
      }
    },
    {
      "@type": "Question",
      "name": "How do I check a Cairns aircon cleaner's ARC licence?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Go to lookup.arctick.org, type the technician name or business trading name, and you should see an active RHL number plus an Australian Refrigeration Council Authorisation (ARC AU) for the business if they handle gas commercially. The licence must be current — not lapsed, not suspended. Ask for the licence number to be shown on the quote itself, and cross-check the name on the ARC register with the name on the invoice. We see roughly one in four Cairns customers who have been quoted by an unlicensed operator, often offering a price that is 30 to 40 per cent below market."
      }
    },
    {
      "@type": "Question",
      "name": "What are the three corner-cuts you see most often in Cairns?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "First, skipping the condenser coil clean on the outdoor unit during a service — the indoor unit gets a quick wipe, but the salt-loaded outdoor coil is the one losing capacity. Second, no drain-line flush, which guarantees a mould bloom and water-damage call-out by February. Third, no anti-microbial treatment on the evaporator coil after washing — the wet-season climate puts it back to square one within four weeks. All three are common with unlicensed operators trying to keep the visit under 45 minutes."
      }
    },
    {
      "@type": "Question",
      "name": "What does an unlicensed cleaning job cost me by year three?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We have done year-three assessments on dozens of Cairns systems first installed or serviced by unlicensed operators. The typical bill is between 1,400 and 2,800 dollars: a compressor that has been running with restricted air-flow across the condenser, a corroded evaporator that needs to be replaced, drain-line water damage to ceiling plaster, and a refrigerant top-up that should never have been needed if the leak had been chased properly. The original cheap quote was 180 dollars instead of 320 — saving 140 to pay 2,000-plus."
      }
    }
  ]
};
